# PostgreSQL connection string from Supabase
# Settings > Database > Connection string > URI (use Transaction pooler port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Migration connection — used only by `drizzle-kit push` (npm run db:push).
# Supavisor SESSION mode: same pooler host as DATABASE_URL but PORT 5432 (session)
# instead of 6543 (transaction). Session mode supports the session-level DDL that
# transaction mode doesn't, and stays IPv4-compatible so it works from Railway
# (which disables outbound IPv6 by default). Do NOT use the direct
# db.[project-ref].supabase.co:5432 endpoint — it's IPv6-only without the Supabase
# IPv4 add-on and fails from Railway with ENETUNREACH.
# Settings > Database > Connection string > Session pooler.
# Optional: falls back to DATABASE_URL when unset.
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Random secret for session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string

# Set to production on Railway
NODE_ENV=production

# Port the server listens on. Railway injects this automatically — leave unset
# there. Defaults to 5000 locally when omitted.
PORT=5000
