# PostgreSQL connection string from Supabase
# Settings > Database > Connection string > URI (use Transaction pooler port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Random secret for session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string

# Set to production on Railway
NODE_ENV=production

# Direct (non-pooled) connection string — used only for migrations (npm run db:push)
# Settings > Database > Connection string > URI (use Direct connection port 5432)
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].postgres.supabase.co:5432/postgres

# Railway sets this automatically in production; only needed for local dev overrides
PORT=5000
